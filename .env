# Environment: development, staging, beta, production
APP_ENV=development

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/divine

# Redis (for idempotency & queues)
REDIS_URL=redis://localhost:6379

# Stripe Issuing (Card Rails)
STRIPE_TEST_KEY=pk_test_xxxxx
STRIPE_LIVE_KEY=pk_live_xxxxx

# Circle (Crypto Rails)
CIRCLE_TEST_API_KEY=test_xxxxx
CIRCLE_LIVE_API_KEY=live_xxxxx

# HSM Configuration
HSM_HOST=localhost
HSM_PORT=1789
HSM_API_KEY=your_hsm_key

# JWT Secret
JWT_SECRET=your_jwt_secret

# Admin Password
ADMIN_PASSWORD=DIVINE
FALLBACK_PIN=4249

# Beta Safety Guardrails
BETA_MAX_TRANSACTION_AMOUNT=1000000000000.00
BETA_ALLOWED_USERS=user1@divine.com,user2@divine.com